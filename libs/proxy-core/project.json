{
  "name": "proxy-core",
  "$schema": "../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "libs/proxy-core/src",
  "projectType": "library",
  "root": "libs/proxy-core",
  "targets": {
    "build": {
      "executor": "@nx/js:tsc",
      "outputs": ["{options.outputPath}"],
      "options": {
        "outputPath": "dist/libs/proxy-core",
        "main": "libs/proxy-core/src/index.ts",
        "tsConfig": "libs/proxy-core/tsconfig.lib.json"
      }
    },
    "test": {
      "executor": "@nx/vite:test",
      "outputs": ["{workspaceRoot}/coverage/libs/proxy-core"],
      "options": {
        "passWithNoTests": true,
        "config": "libs/proxy-core/vite.config.ts"
      }
    },
    "lint": {
      "executor": "@nx/eslint:lint",
      "options": {
        "lintFilePatterns": ["libs/proxy-core/**/*.ts"]
      }
    },
    "typecheck": {
      "executor": "nx:run-commands",
      "options": {
        "command": "tsc -p tsconfig.lib.json --noEmit",
        "cwd": "libs/proxy-core"
      }
    }
  },
  "tags": ["type:lib", "scope:proxy-core"]
}
