{
  "npm": {
    "publish": false
  },
  "git": {
    "commitMessage": "chore: release v${version}",
    "tagName": "v${version}",
    "tagAnnotation": "Release v${version}"
  },
  "github": {
    "release": false
  },
  "hooks": {
    "after:bump": "npm pkg set version=${version} --prefix apps/cli && git add apps/cli/package.json"
  }
}
