{
  "name": "portswitch",
  "version": "1.0.0",
  "private": true,
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "workspaces": [
    "apps/*",
    "libs/*"
  ],
  "scripts": {
    "nx": "nx",
    "build": "nx run-many -t build",
    "test": "nx run-many -t test",
    "lint": "nx run-many -t lint",
    "typecheck": "nx run-many -t typecheck",
    "serve": "nx run cli:build && node dist/apps/cli/main.js serve",
    "serve:ui": "nx run cli:copy-ui && node dist/apps/cli/main.js serve",
    "web:dev": "nx run web:serve",
    "desktop:build": "nx run desktop:build",
    "desktop:electron": "npx electron dist/apps/desktop/main/main.js",
    "desktop:package": "nx run desktop:package",
    "desktop:test": "nx run desktop:test",
    "cli:build": "nx run cli:build",
    "cli:copy-ui": "nx run cli:copy-ui",
    "cli:test": "nx run cli:test",
    "cli": "node dist/apps/cli/main.js",
    "e2e": "npx playwright test"
  },
  "dependencies": {
    "chalk": "^4.1.2",
    "commander": "^4.1.1",
    "express": "^4.21.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "ulid": "^2.3.0",
    "ws": "^8.18.0",
    "zod": "^3.23.0"
  },
  "devDependencies": {
    "@nx/esbuild": "^19.8.0",
    "@nx/eslint": "^19.8.0",
    "@nx/eslint-plugin": "^19.8.0",
    "@nx/js": "^19.8.0",
    "@nx/node": "^19.8.0",
    "@nx/vite": "^19.8.0",
    "@playwright/test": "^1.60.0",
    "@rollup/rollup-linux-x64-gnu": "^4.60.4",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/express": "^4.17.0",
    "@types/node": "^20.14.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@types/supertest": "^6.0.0",
    "@types/ws": "^8.5.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "@vitest/coverage-v8": "^1.6.0",
    "electron": "^42.2.0",
    "electron-builder": "^26.8.1",
    "esbuild": "~0.19.2",
    "eslint": "^8.57.0",
    "jsdom": "^29.1.1",
    "nx": "^19.8.0",
    "prettier": "^3.3.0",
    "supertest": "^7.0.0",
    "tsup": "^8.3.0",
    "typescript": "~5.5.0",
    "vite": "^5.4.0",
    "vitest": "^1.6.0"
  }
}
